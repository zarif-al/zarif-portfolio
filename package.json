{
  "name": "zarif-portfolio",
  "version": "1.0.0",
  "description": "Zarif's portfolio — built with Payload CMS and Next.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "seed": "tsx scripts/seed"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@payloadcms/db-mongodb": "3.85.0",
    "@payloadcms/live-preview-react": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/storage-s3": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "jimp": "^1.6.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "payload": "3.85.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.54.2",
    "shadcn": "^4.7.0",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.6.0",
    "thumbhash": "^0.1.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "28.0.0",
    "postcss": "^8.5.14",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "ts-essentials": "^10.0.3",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.59.2",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10 || ^11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
